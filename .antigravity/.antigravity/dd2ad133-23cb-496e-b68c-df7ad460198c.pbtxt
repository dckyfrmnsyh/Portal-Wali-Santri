  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express, { Request, Response } from \"express\";\nimport path from \"path\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI } from \"@google/genai\";\n\nconst app = express();\nconst PORT = 3000;\n\napp.use(express.json({ limit: \"50mb\" }));\n\n// Lazy-loaded Gemini client to prevent crash if key is missing on startup\nlet aiInstance: GoogleGenAI | null = null;\n\nfunction getGeminiClient(): GoogleGenAI {\n  if (!aiInstance) {\n    const apiKey = process.env.GEMINI_API_KEY;\n    if (!apiKey) {\n      throw new Error(\"GEMINI_API_KEY environment variable is required. Please add it via the Secrets panel in Settings.\");\n    }\n    aiInstance = new GoogleGenAI({\n      apiKey,\n      httpOptions: {\n        headers: {\n          \"User-Agent\": \"aistudio-build\",\n        },\n      },\n    });\n  }\n  return aiInstance;\n}\n\n// API endpoint 1: Research Grounding (using Google Search grounding)\napp.post(\"/api/research\", async (req: Request, res: Response) => {\n  try {\n    const { prompt } = req.body;\n    if (!prompt) {\n      res.status(400).json({ error: \"Prompt is required\" });\n      return;\n    }\n\n    const ai = getGeminiClient();\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: prompt,\n      config: {\n        tools: [{ googleSearch: {} }],\n        systemInstruction: \"You are a professional research assistant. Provide objective, factual answers based on web search results, citing your findings directly in a clean, comprehensive manner. Keep response informative yet readable.\",\n      },\n    });\n\n    const text = response.text || \"No response generated.\";\n    const chunks = response.candidates?.[0]?.groundingMetadata?.groundingChunks || [];\n    const webSearchQueries = response.candidates?.[0]?.groundingMetadata?.webSearchQueries || [];\n\n    res.json({ text, chunks, webSearchQueries });\n  } catch (err: any) {\n    console.error(\"Error in /api/research:\", err);\n    res.status(500).json({ error: err.message || \"An error occurred during AI search grounding\" });\n  }\n});\n\n// API endpoint 2: Note Co-authoring / Assistant\napp.post(\"/api/notes/coauthor\", async (req: Request, res: Response) => {\n  try {\n    const { noteText, command, customPrompt } = req.body;\n    if (!command) {\n      res.status(400).json({ error: \"Command is required\" });\n      return;\n    }\n\n    const ai = getGeminiClient();\n\n    let systemPrompt = \"You are an expert editor and writing co-author. \";\n    let promptText = \"\";\n\n    switch (command) {\n      case \"summarize\":\n        systemPrompt += \"Summarize the provided notes concisely, outlining the main action points and highlights using elegant markdown list formatting.\";\n        promptText = `Notes to summarize:\\n\\n${noteText || \"(Empty note)\"}`;\n        break;\n      case \"outline\":\n        systemPrompt += \"Create a highly structured, logical outline from the provided notes using Markdown headings and bullet points. Expand on points if necessary to make them professional.\";\n        promptText = `Notes to outline:\\n\\n${noteText || \"(Empty note)\"}`;\n        break;\n      case \"improve\":\n        systemPrompt += \"Improve the professional tone, clarity, and grammatical correctness of the provided notes. Maintain the original structure but make the phrasing more elegant and refined. Return the revised note content in clean Markdown.\";\n        promptText = `Notes to improve:\\n\\n${noteText || \"(Empty note)\"}`;\n        break;\n      case \"continue\":\n        systemPrompt += \"Read the provided notes and smoothly continue writing the next section or paragraph. Match the tone, style, and vocabulary of the user. Return only the continued section/paragraph.\";\n        promptText = `Current notes:\\n\\n${noteText || \"\"}\\n\\n[Continue writing from here]`;\n        break;\n      case \"custom\":\n        systemPrompt += \"Assist the user with their notes as requested. Format your output cleanly in Markdown.\";\n        promptText = `Current notes:\\n\\n${noteText || \"\"}\\n\\nUser request: ${customPrompt || \"Format this note\"}`;\n        break;\n      default:\n        systemPrompt += \"Format the provided notes into clean Markdown.\";\n        promptText = `Notes:\\n\\n${noteText || \"\"}`;\n    }\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: promptText,\n      config: {\n        systemInstruction: systemPrompt,\n        temperature: 0.7,\n      },\n    });\n\n    res.json({ text: response.text || \"\" });\n  } catch (err: any) {\n    console.error(\"Error in /api/notes/coauthor:\", err);\n    res.status(500).json({ error: err.message || \"An error occurred during note co-authoring\" });\n  }\n});\n\n// API endpoint 3: Image Canvas (Generate concept artwork/diagrams)\napp.post(\"/api/visualize\", async (req: Request, res: Response) => {\n  try {\n    const { prompt, aspectRatio } = req.body;\n    if (!prompt) {\n      res.status(400).json({ error: \"Prompt is required\" });\n      return;\n    }\n\n    const ai = getGeminiClient();\n    const response = await ai.models.generateContent({\n      model: \"gemini-2.5-flash-image\",\n      contents: {\n        parts: [{ text: prompt }],\n      },\n      config: {\n        imageConfig: {\n          aspectRatio: aspectRatio || \"1:1\",\n        },\n      },\n    });\n\n    let base64Image = \"\";\n    for (const part of response.candidates?.[0]?.content?.parts || []) {\n      if (part.inlineData) {\n        base64Image = part.inlineData.data;\n        break;\n      }\n    }\n\n    if (!base64Image) {\n      // Check if text was returned instead (e.g. if safety or other reason blocked generation)\n      let textResponse = \"\";\n      for (const part of response.candidates?.[0]?.content?.parts || []) {\n        if (part.text) textResponse += part.text;\n      }\n      res.status(500).json({ error: textResponse || \"Image generation did not return image data.\" });\n      return;\n    }\n\n    res.json({ imageUrl: `data:image/png;base64,${base64Image}` });\n  } catch (err: any) {\n    console.error(\"Error in /api/visualize:\", err);\n    res.status(500).json({ error: err.message || \"An error occurred during image generation\" });\n  }\n});\n\n// Setup Vite Dev Server / Static files\nasync function setupServer() {\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \"dist\");\n    app.use(express.static(distPath));\n    app.get(\"*\", (req, res) => {\n      res.sendFile(path.join(distPath, \"index.html\"));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`Server running on http://localhost:${PORT}`);\n  });\n}\n\nsetupServer().catch((err) => {\n  console.error(\"Failed to start server:\", err);\n});\n"
    }
