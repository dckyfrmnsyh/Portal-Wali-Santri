    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { \n  FileEdit, Eye, FilePlus, Trash2, Sparkles, CheckCircle2, \n  Loader2, RefreshCw, Heading1, Heading2, List, Bold, Italic, CornerDownLeft\n} from \"lucide-react\";\nimport { Note } from \"../types\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface ZenEditorProps {\n  notes: Note[];\n  selectedNoteId: string | null;\n  onSelectNote: (id: string) => void;\n  onAddNote: (note: Note) => void;\n  onUpdateNote: (id: string, updates: Partial<Note>) => void;\n  onDeleteNote: (id: string) => void;\n}\n\n// Light Regex-based Markdown compiler that renders to structured, beautiful Tailwind elements\nconst renderMarkdown = (text: string) => {\n  if (!text) return <p className=\"text-slate-400 italic text-sm\">Write markdown on the left to see the elegant compiled output here...</p>;\n\n  const lines = text.split(\"\\n\");\n  let inList = false;\n  let listItems: string[] = [];\n  const renderedElements: React.ReactNode[] = [];\n\n  const parseInlineMarkdown = (content: string) => {\n    // Escape simple tags or format safe inline elements\n    let parts: React.ReactNode[] = [content];\n\n    // Bold formatting: **text** or __text__\n    const boldRegex = /\\*\\*(.*?)\\*\\*/g;\n    let match;\n    \n    // We can do standard text manipulation for bold/italic/code in custom renderer\n    // For ultimate stability, convert bold and code segments\n    content = content.replace(/\\*\\*(.*?)\\*\\*/g, \"<strong>$1</strong>\");\n    content = content.replace(/\\*(.*?)\\*/g, \"<em>$1</em>\");\n    content = content.replace(/`(.*?)`/g, \"<code class=\'bg-slate-100 text-rose-600 px-1.5 py-0.5 rounded font-mono text-[12px]\'>$1</code>\");\n\n    return <span dangerouslySetInnerHTML={{ __html: content }} />;\n  };\n\n  const flushList = (key: number) => {\n    if (listItems.length > 0) {\n      renderedElements.push(\n        <ul key={`list-${key}`} className=\"list-disc pl-6 space-y-1 mb-4 text-slate-600 text-sm\">\n          {listItems.map((item, idx) => (\n            <li key={idx}>{parseInlineMarkdown(item)}</li>\n          ))}\n        </ul>\n      );\n      listItems = [];\n      inList = false;\n    }\n  };\n\n  lines.forEach((line, index) => {\n    // Check headings\n    if (line.startsWith(\"# \")) {\n      flushList(index);\n      renderedElements.push(\n        <h1 key={index} className=\"text-2xl font-bold text-slate-800 border-b border-slate-100 pb-2 mb-4 mt-6 first:mt-0\">\n          {parseInlineMarkdown(line.substring(2))}\n        </h1>\n      );\n    } else if (line.startsWith(\"## \")) {\n      flushList(index);\n      renderedElements.push(\n        <h2 key={index} className=\"text-xl font-bold text-slate-800 mb-3 mt-5\">\n          {parseInlineMarkdown(line.substring(3))}\n        </h2>\n      );\n    } else if (line.startsWith(\"### \")) {\n      flushList(index);\n      renderedElements.push(\n        <h3 key={index} className=\"text-lg font-semibold text-slate-800 mb-2 mt-4\">\n          {parseInlineMarkdown(line.substring(4))}\n        </h3>\n      );\n    } else if (line.startsWith(\"- \") || line.startsWith(\"* \")) {\n      inList = true;\n      listItems.push(line.substring(2));\n    } else if (line.trim() === \"\") {\n      flushList(index);\n      // Empty line -> paragraph break\n      renderedElements.push(<div key={index} className=\"h-2\" />);\n    } else if (line.startsWith(\"> \")) {\n      flushList(index);\n      renderedElements.push(\n        <blockquote key={index} className=\"border-l-4 border-indigo-500 bg-indigo-50/50 px-4 py-3 rounded-r-lg text-slate-700 italic my-4 text-sm leading-relaxed\">\n          {parseInlineMarkdown(line.substring(2))}\n        </blockquote>\n      );\n    } else if (line.startsWith(\"```\")) {\n      flushList(index);\n      // Simplify code blocks\n      renderedElements.push(\n        <div key={index} className=\"my-4 p-4 bg-slate-900 rounded-xl text-slate-200 font-mono text-xs overflow-x-auto border border-slate-800\">\n          <pre>{line.includes(\"```\") && line.length > 3 ? line.substring(3) + \"\\n\" : \"\"}</pre>\n        </div>\n      );\n    } else {\n      flushList(index);\n      renderedElements.push(\n        <p key={index} className=\"text-slate-600 text-sm leading-relaxed mb-3\">\n          {parseInlineMarkdown(line)}\n        </p>\n      );\n    }\n  });\n\n  // Flush any remaining list items at EOF\n  flushList(lines.length);\n\n  return <div className=\"space-y-1\">{renderedElements}</div>;\n};\n\nexport default function ZenEditor({\n  notes,\n  selectedNoteId,\n  onSelectNote,\n  onAddNote,\n  onUpdateNote,\n  onDeleteNote,\n}: ZenEditorProps) {\n  const [activeTab, setActiveTab] = useState<\"edit\" | \"split\" | \"preview\">(\"split\");\n  const [isAiLoading, setIsAiLoading] = useState(false);\n  const [customPrompt, setCustomPrompt] = useState(\"\");\n  const [aiError, setAiError] = useState<string | null>(null);\n\n  const selectedNote = notes.find((n) => n.id === selectedNoteId) || null;\n\n  const handleCreateNote = () => {\n    const newNote: Note = {\n      id: crypto.randomUUID(),\n      title: `Untitled Note`,\n      content: \"# Your Note Header\\n\\nWrite down your initial observations here. Try selecting an option on the AI workspace sidebar to improve or analyze your note seamlessly.\",\n      createdAt: new Date().toISOString(),\n      updatedAt: new Date().toISOString(),\n    };\n    onAddNote(newNote);\n    onSelectNote(newNote.id);\n  };\n\n  const handleContentChange = (content: string) => {\n    if (selectedNoteId) {\n      onUpdateNote(selectedNoteId, {\n        content,\n        updatedAt: new Date().toISOString(),\n      });\n    }\n  };\n\n  const handleTitleChange = (title: string) => {\n    if (selectedNoteId) {\n      onUpdateNote(selectedNoteId, {\n        title: title || \"Untitled Note\",\n        updatedAt: new Date().toISOString(),\n      });\n    }\n  };\n\n  // Trigger server-side AI note operation\n  const triggerAiCoauthor = async (command: string) => {\n    if (!selectedNote) return;\n    setIsAiLoading(true);\n    setAiError(null);\n\n    try {\n      const response = await fetch(\"/api/notes/coauthor\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          noteText: selectedNote.content,\n          command,\n          customPrompt: command === \"custom\" ? customPrompt : undefined,\n        }),\n      });\n\n      const data = await response.json();\n      if (!response.ok) {\n        throw new Error(data.error || \"Failed to trigger AI Co-author\");\n      }\n\n      if (data.text) {\n        let newContent = selectedNote.content;\n        if (command === \"continue\") {\n          // Append continued text cleanly\n          newContent = `${newContent}\\n\\n${data.text}`;\n        } else {\n          // Replace or format\n          newContent = data.text;\n        }\n\n        onUpdateNote(selectedNote.id, {\n          content: newContent,\n          updatedAt: new Date().toISOString(),\n        });\n        if (command === \"custom\") {\n          setCustomPrompt(\"\");\n        }\n      }\n    } catch (err: any) {\n      console.error(err);\n      setAiError(err.message || \"Something went wrong while connecting with Gemini\");\n    } finally {\n      setIsAiLoading(false);\n    }\n  };\n\n  const insertMarkdownTag = (tagType: string) => {\n    if (!selectedNote) return;\n    const textarea = document.getElementById(\"zen-editor-textarea\") as HTMLTextAreaElement;\n    if (!textarea) return;\n\n    const startPos = textarea.selectionStart;\n    const endPos = textarea.selectionEnd;\n    const text = selectedNote.content;\n    const selectedText = text.substring(startPos, endPos);\n\n    let replacement = \"\";\n    switch (tagType) {\n      case \"bold\":\n        replacement = `**${selectedText || \"bold text\"}**`;\n        break;\n      case \"italic\":\n        replacement = `*${selectedText || \"italic text\"}*`;\n        break;\n      case \"h1\":\n        replacement = `\\n# ${selectedText || \"Heading 1\"}\\n`;\n        break;\n      case \"h2\":\n        replacement = `\\n## ${selectedText || \"Heading 2\"}\\n`;\n        break;\n      case \"list\":\n        replacement = `\\n- ${selectedText || \"List item\"}\\n`;\n        break;\n      default:\n        return;\n    }\n\n    const updatedText = text.substring(0, startPos) + replacement + text.substring(endPos);\n    handleContentChange(updatedText);\n\n    // Refocus & set cursor\n    setTimeout(() => {\n      textarea.focus();\n      textarea.setSelectionRange(startPos + replacement.length, startPos + replacement.length);\n    }, 50);\n  };\n\n  // Stats\n  const charCount = selectedNote?.content.length || 0;\n  const wordCount = selectedNote?.content.trim() ? selectedNote.content.trim().split(/\\s+/).length : 0;\n\n  return (\n    <div id=\"zen-editor-container\" className=\"grid grid-cols-1 xl:grid-cols-4 gap-6 h-[calc(100vh-180px)] min-h-[500px]\">\n      {/* Sidebar: Notes List */}\n      <div className=\"xl:col-span-1 bg-white border border-slate-100 rounded-2xl p-4 shadow-xs flex flex-col h-full\">\n        <div className=\"flex items-center justify-between mb-4 pb-2 border-b border-slate-50\">\n          <span className=\"text-xs font-bold text-slate-400 uppercase tracking-wider\">Your Notebook</span>\n          <button\n            onClick={handleCreateNote}\n            className=\"flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl text-xs font-semibold transition-all hover:scale-102 active:scale-98\"\n          >\n            <FilePlus className=\"w-3.5 h-3.5\" />\n            New Note\n          </button>\n        </div>\n\n        {/* Note List Scroll Area */}\n        <div className=\"flex-1 overflow-y-auto space-y-2 pr-1 custom-scrollbar\">\n          {notes.length === 0 ? (\n            <div className=\"text-center py-12 px-4 border-2 border-dashed border-slate-50 rounded-xl\">\n              <p className=\"text-xs font-medium text-slate-400\">No notes created yet</p>\n              <button\n                onClick={handleCreateNote}\n                className=\"text-[11px] text-indigo-500 font-semibold mt-2 hover:underline\"\n              >\n                Create note\n              </button>\n            </div>\n          ) : (\n            notes.map((note) => (\n              <div\n                key={note.id}\n                onClick={() => onSelectNote(note.id)}\n                className={`group flex items-start justify-between p-3 rounded-xl border cursor-pointer transition-all ${\n                  selectedNoteId === note.id\n                    ? \"bg-slate-50 border-slate-200 text-slate-900\"\n                    : \"border-transparent bg-white hover:bg-slate-50 text-slate-600\"\n                }`}\n              >\n                <div className=\"flex-1 min-w-0 pr-2\">\n                  <p className=\"text-xs font-semibold truncate\">\n                    {note.title || \"Untitled Note\"}\n                  </p>\n                  <p className=\"text-[10px] text-slate-400 mt-1 truncate\">\n                    {note.content.replace(/[#*`_]/g, \"\").substring(0, 45) || \"Empty note\"}\n                  </p>\n                </div>\n\n                <button\n                  onClick={(e) => {\n                    e.stopPropagation();\n                    if (confirm(\"Are you sure you want to delete this note?\")) {\n                      onDeleteNote(note.id);\n                    }\n                  }}\n                  className=\"opacity-0 group-hover:opacity-100 hover:text-red-500 p-1 text-slate-400 transition-opacity\"\n                  title=\"Delete Note\"\n                >\n                  <Trash2 className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n            ))\n          )}\n        </div>\n      </div>\n\n      {/* Main Area: Editor / Preview + AI Sidebar */}\n      <div className=\"xl:col-span-3 flex flex-col lg:flex-row gap-6 h-full\">\n        {/* Editor & Preview Pane */}\n        <div className=\"flex-1 bg-white border border-slate-100 rounded-2xl p-5 shadow-xs flex flex-col h-full\">\n          {selectedNote ? (\n            <>\n              {/* Note Header Info */}\n              <div className=\"flex flex-col sm:flex-row gap-3 sm:items-center justify-between pb-4 border-b border-slate-100 mb-4\">\n                <input\n                  type=\"text\"\n                  value={selectedNote.title}\n                  onChange={(e) => handleTitleChange(e.target.value)}\n                  placeholder=\"Enter note title...\"\n                  className=\"font-bold text-lg text-slate-800 outline-hidden border-b border-transparent hover:border-slate-200 focus:border-indigo-500 pb-0.5 max-w-sm transition-all\"\n                />\n\n                {/* Pane layout tabs */}\n                <div className=\"flex bg-slate-100 p-1 rounded-xl self-start\">\n                  <button\n                    onClick={() => setActiveTab(\"edit\")}\n                    className={`flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all ${\n                      activeTab === \"edit\" ? \"bg-white text-slate-800 shadow-xs\" : \"text-slate-500 hover:text-slate-700\"\n                    }`}\n                  >\n                    <FileEdit className=\"w-3.5 h-3.5\" />\n                    Write\n                  </button>\n                  <button\n                    onClick={() => setActiveTab(\"split\")}\n                    className={`hidden sm:flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all ${\n                      activeTab === \"split\" ? \"bg-white text-slate-800 shadow-xs\" : \"text-slate-500 hover:text-slate-700\"\n                    }`}\n                  >\n                    Split\n                  </button>\n                  <button\n                    onClick={() => setActiveTab(\"preview\")}\n                    className={`flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all ${\n                      activeTab === \"preview\" ? \"bg-white text-slate-800 shadow-xs\" : \"text-slate-500 hover:text-slate-700\"\n                    }`}\n                  >\n                    <Eye className=\"w-3.5 h-3.5\" />\n                    Preview\n                  </button>\n                </div>\n              </div>\n\n              {/* Formatting Helper Bar */}\n              {activeTab !== \"preview\" && (\n                <div className=\"flex gap-2 mb-3 bg-slate-50 border border-slate-100 p-1.5 rounded-lg\">\n                  <button onClick={() => insertMarkdownTag(\"h1\")} className=\"p-1 hover:bg-white rounded hover:shadow-xs text-slate-500\" title=\"Heading 1\">\n                    <Heading1 className=\"w-3.5 h-3.5\" />\n                  </button>\n                  <button onClick={() => insertMarkdownTag(\"h2\")} className=\"p-1 hover:bg-white rounded hover:shadow-xs text-slate-500\" title=\"Heading 2\">\n                    <Heading2 className=\"w-3.5 h-3.5\" />\n                  </button>\n                  <button onClick={() => insertMarkdownTag(\"bold\")} className=\"p-1 hover:bg-white rounded hover:shadow-xs text-slate-500\" title=\"Bold\">\n                    <Bold className=\"w-3.5 h-3.5\" />\n                  </button>\n                  <button onClick={() => insertMarkdownTag(\"italic\")} className=\"p-1 hover:bg-white rounded hover:shadow-xs text-slate-500\" title=\"Italic\">\n                    <Italic className=\"w-3.5 h-3.5\" />\n                  </button>\n                  <button onClick={() => insertMarkdownTag(\"list\")} className=\"p-1 hover:bg-white rounded hover:shadow-xs text-slate-500\" title=\"Bulleted List\">\n                    <List className=\"w-3.5 h-3.5\" />\n                  </button>\n                </div>\n              )}\n\n              {/* Workspaces Layout */}\n              <div className=\"flex-1 grid grid-cols-1 md:grid-cols-2 gap-4 min-h-0 overflow-hidden\">\n                {/* Markdown Input Editor */}\n                {(activeTab === \"edit\" || activeTab === \"split\") && (\n                  <textarea\n                    id=\"zen-editor-textarea\"\n                    value={selectedNote.content}\n                    onChange={(e) => handleContentChange(e.target.value)}\n                    placeholder=\"Start drafting in Markdown...\"\n                    className={`w-full h-full p-4 font-mono text-xs text-slate-700 bg-slate-50 rounded-xl outline-hidden resize-none focus:ring-1 focus:ring-indigo-200 border border-slate-100 ${\n                      activeTab === \"edit\" ? \"md:col-span-2\" : \"md:col-span-1\"\n                    }`}\n                  />\n                )}\n\n                {/* Elegant Live HTML Render Preview */}\n                {(activeTab === \"preview\" || activeTab === \"split\") && (\n                  <div\n                    className={`h-full overflow-y-auto p-4 border border-slate-100 bg-white rounded-xl custom-scrollbar prose prose-slate max-w-none ${\n                      activeTab === \"preview\" ? \"md:col-span-2\" : \"md:col-span-1\"\n                    }`}\n                  >\n                    {renderMarkdown(selectedNote.content)}\n                  </div>\n                )}\n              </div>\n\n              {/* Note Footer Indicators */}\n              <div className=\"flex justify-between items-center text-[10px] text-slate-400 pt-3 border-t border-slate-50 mt-3 font-medium\">\n                <div className=\"flex gap-3\">\n                  <span>{charCount} Characters</span>\n                  <span>{wordCount} Words</span>\n                </div>\n                <span>Last updated {new Date(selectedNote.updatedAt).toLocaleTimeString()}</span>\n              </div>\n            </>\n          ) : (\n            <div className=\"flex-1 flex flex-col items-center justify-center text-center p-6 text-slate-400\">\n              <Sparkles className=\"w-12 h-12 text-slate-200 mb-3 animate-pulse\" />\n              <p className=\"text-sm font-semibold\">No Note Selected</p>\n              <p className=\"text-xs text-slate-300 mt-1 max-w-[280px]\">\n                Create a fresh markdown sheet, or click an existing note from the side panel to edit with AI tools!\n              </p>\n            </div>\n          )}\n        </div>\n\n        {/* AI Co-author Toolbox (Saves space and keeps logical division) */}\n        {selectedNote && (\n          <div className=\"w-full lg:w-64 bg-slate-50 border border-slate-200 rounded-2xl p-4 flex flex-col gap-4\">\n            <div className=\"flex items-center gap-1.5 pb-2 border-b border-slate-100\">\n              <Sparkles className=\"w-4 h-4 text-indigo-600\" />\n              <span className=\"text-xs font-bold text-slate-700 uppercase tracking-wider\">AI Co-Author</span>\n            </div>\n\n            <div className=\"space-y-2 flex-1 overflow-y-auto pr-0.5\">\n              <button\n                disabled={isAiLoading}\n                onClick={() => triggerAiCoauthor(\"improve\")}\n                className=\"w-full flex items-center gap-2 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-200 rounded-xl text-xs font-medium text-slate-700 hover:text-slate-800 disabled:opacity-50 text-left transition-all hover:-translate-y-0.5 active:translate-y-0\"\n              >\n                <RefreshCw className={`w-3.5 h-3.5 text-indigo-500 ${isAiLoading ? \"animate-spin\" : \"\"}`} />\n                Improve & Polish Tone\n              </button>\n\n              <button\n                disabled={isAiLoading}\n                onClick={() => triggerAiCoauthor(\"summarize\")}\n                className=\"w-full flex items-center gap-2 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-200 rounded-xl text-xs font-medium text-slate-700 hover:text-slate-800 disabled:opacity-50 text-left transition-all hover:-translate-y-0.5 active:translate-y-0\"\n              >\n                <CheckCircle2 className=\"w-3.5 h-3.5 text-emerald-500\" />\n                Summarize Notes\n              </button>\n\n              <button\n                disabled={isAiLoading}\n                onClick={() => triggerAiCoauthor(\"outline\")}\n                className=\"w-full flex items-center gap-2 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-200 rounded-xl text-xs font-medium text-slate-700 hover:text-slate-800 disabled:opacity-50 text-left transition-all hover:-translate-y-0.5 active:translate-y-0\"\n              >\n                <Heading1 className=\"w-3.5 h-3.5 text-blue-500\" />\n                Generate Outline\n              </button>\n\n              <button\n                disabled={isAiLoading}\n                onClick={() => triggerAiCoauthor(\"continue\")}\n                className=\"w-full flex items-center gap-2 px-3 py-2 bg-white hover:bg-slate-100 border border-slate-200 rounded-xl text-xs font-medium text-slate-700 hover:text-slate-800 disabled:opacity-50 text-left transition-all hover:-translate-y-0.5 active:translate-y-0\"\n              >\n                <CornerDownLeft className=\"w-3.5 h-3.5 text-purple-500\" />\n                Continue Writing\n              </button>\n            </div>\n\n            {/* Custom Assistant Box */}\n            <div className=\"border-t border-slate-200 pt-3 space-y-2\">\n              <label className=\"text-[10px] font-bold text-slate-500 uppercase tracking-wider block\">Custom AI Request:</label>\n              <div className=\"relative\">\n                <textarea\n                  value={customPrompt}\n                  onChange={(e) => setCustomPrompt(e.target.value)}\n                  placeholder=\"e.g. Translate to Spanish or translate into bullet items...\"\n                  disabled={isAiLoading}\n                  className=\"w-full p-2.5 text-xs bg-white border border-slate-200 rounded-xl h-20 outline-hidden resize-none focus:ring-1 focus:ring-indigo-300 focus:border-indigo-400 text-slate-700\"\n                />\n                <button\n                  onClick={() => triggerAiCoauthor(\"custom\")}\n                  disabled={isAiLoading || !customPrompt.trim()}\n                  className=\"absolute bottom-2 right-2 p-1.5 bg-slate-900 hover:bg-slate-800 disabled:bg-slate-200 text-white disabled:text-slate-400 rounded-lg transition-all\"\n                  title=\"Run Prompt\"\n                >\n                  {isAiLoading ? <Loader2 className=\"w-3.5 h-3.5 animate-spin\" /> : <Sparkles className=\"w-3.5 h-3.5\" />}\n                </button>\n              </div>\n            </div>\n\n            {/* Loading / Error states */}\n            <AnimatePresence>\n              {isAiLoading && (\n                <motion.div\n                  initial={{ opacity: 0, y: 10 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  exit={{ opacity: 0, y: 10 }}\n                  className=\"bg-indigo-50 border border-indigo-100 p-2.5 rounded-xl flex items-center gap-2\"\n                >\n                  <Loader2 className=\"w-3.5 h-3.5 text-indigo-600 animate-spin shrink-0\" />\n                  <span className=\"text-[10px] text-indigo-600 font-semibold\">Gemini co-author is working...</span>\n                </motion.div>\n              )}\n\n              {aiError && (\n                <motion.div\n                  initial={{ opacity: 0, y: 10 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  exit={{ opacity: 0, y: 10 }}\n                  className=\"bg-rose-50 border border-rose-100 p-2.5 rounded-xl\"\n                >\n                  <p className=\"text-[10px] text-rose-600 font-semibold\">AI Error</p>\n                  <p className=\"text-[9px] text-rose-500 mt-0.5 leading-normal\">{aiError}</p>\n                </motion.div>\n              )}\n            </AnimatePresence>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"
