      replacement_content: "import React, { useState, useEffect, useRef } from \"react\";\nimport { Play, Pause, RotateCcw, Flame, CheckCircle, TrendingUp, Sparkles, Clock } from \"lucide-react\";\nimport { FocusSession } from \"../types\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface FocusInsightProps {\n  sessions: FocusSession[];\n  onAddSession: (session: FocusSession) => void;\n  onClearSessions: () => void;\n}\n\nconst CATEGORIES = [\n  { id: \"Writing\", color: \"bg-emerald-500\", border: \"border-emerald-500\", text: \"text-emerald-500\" },\n  { id: \"Research\", color: \"bg-indigo-500\", border: \"border-indigo-500\", text: \"text-indigo-500\" },\n  { id: \"Creative\", color: \"bg-amber-500\", border: \"border-amber-500\", text: \"text-amber-500\" },\n  { id: \"General\", color: \"bg-slate-500\", border: \"border-slate-500\", text: \"text-slate-500\" },\n];\n\nexport default function FocusInsight({ sessions, onAddSession, onClearSessions }: FocusInsightProps) {\n  const [activeCategory, setActiveCategory] = useState(\"Writing\");\n  const [duration, setDuration] = useState(25); // Minutes\n  const [timeLeft, setTimeLeft] = useState(25 * 60); // Seconds\n  const [isRunning, setIsRunning] = useState(false);\n  const [mode, setMode] = useState<\"focus\" | \"break\">(\"focus\");\n\n  const intervalRef = useRef<NodeJS.Timeout | null>(null);\n\n  // Sync timeLeft when duration changes (only if not currently running)\n  useEffect(() => {\n    if (!isRunning && mode === \"focus\") {\n      setTimeLeft(duration * 60);\n    }\n  }, [duration, isRunning, mode]);\n\n  useEffect(() => {\n    if (isRunning) {\n      intervalRef.current = setInterval(() => {\n        setTimeLeft((prev) => {\n          if (prev <= 1) {\n            // Timer complete\n            handleTimerComplete();\n            return 0;\n          }\n          return prev - 1;\n        });\n      }, 1000);\n    } else {\n      if (intervalRef.current) {\n        clearInterval(intervalRef.current);\n      }\n    }\n\n    return () => {\n      if (intervalRef.current) {\n        clearInterval(intervalRef.current);\n      }\n    };\n  }, [isRunning, mode, duration, activeCategory]);\n\n  const handleTimerComplete = () => {\n    setIsRunning(false);\n    if (intervalRef.current) clearInterval(intervalRef.current);\n\n    if (mode === \"focus\") {\n      const newSession: FocusSession = {\n        id: crypto.randomUUID(),\n        duration,\n        category: activeCategory,\n        completedAt: new Date().toISOString(),\n      };\n      onAddSession(newSession);\n\n      // Transition to break\n      setMode(\"break\");\n      setTimeLeft(5 * 60); // 5 min break\n      alert(`Great job! You\'ve completed your focus session on ${activeCategory}. Time for a 5-minute break!`);\n    } else {\n      setMode(\"focus\");\n      setTimeLeft(duration * 60);\n      alert(\"Break is over! Ready to focus again?\");\n    }\n  };\n\n  const toggleTimer = () => {\n    setIsRunning(!isRunning);\n  };\n\n  const resetTimer = () => {\n    setIsRunning(false);\n    if (intervalRef.current) clearInterval(intervalRef.current);\n    if (mode === \"focus\") {\n      setTimeLeft(duration * 60);\n    } else {\n      setTimeLeft(5 * 60);\n    }\n  };\n\n  const selectDuration = (mins: number) => {\n    setIsRunning(false);\n    setMode(\"focus\");\n    setDuration(mins);\n    setTimeLeft(mins * 60);\n  };\n\n  // Helper formatting minutes:seconds\n  const formatTime = (secs: number) => {\n    const m = Math.floor(secs / 60);\n    const s = secs % 60;\n    return `${m.toString().padStart(2, \"0\")}:${s.toString().padStart(2, \"0\")}`;\n  };\n\n  // Calculate stats\n  const totalMinutes = sessions.reduce((acc, s) => acc + s.duration, 0);\n  const categoryStats = CATEGORIES.reduce((acc, cat) => {\n    const mins = sessions.filter((s) => s.category === cat.id).reduce((sum, s) => sum + s.duration, 0);\n    acc[cat.id] = mins;\n    return acc;\n  }, {} as Record<string, number>);\n\n  const maxMins = Math.max(...Object.values(categoryStats), 1);\n\n  // SVG ring math\n  const totalDurationSeconds = mode === \"focus\" ? duration * 60 : 5 * 60;\n  const progress = totalDurationSeconds > 0 ? (totalDurationSeconds - timeLeft) / totalDurationSeconds : 0;\n  const strokeDashoffset = 282.6 * (1 - progress);\n\n  return (\n    <div id=\"focus-insight-container\" className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-7xl mx-auto h-full\">\n      {/* Left 2 Cols: Timer & Controls */}\n      <div className=\"lg:col-span-2 space-y-6\">\n        <div id=\"timer-card\" className=\"bg-white border border-slate-100 rounded-2xl p-8 shadow-xs flex flex-col items-center relative overflow-hidden\">\n          {/* Subtle decorative grid background */}\n          <div className=\"absolute inset-0 bg-grid-slate-100 [mask-image:linear-gradient(0deg,white,rgba(255,255,255,0.6))] pointer-events-none opacity-40\" />\n\n          <div className=\"relative z-10 w-full flex justify-between items-center mb-6\">\n            <div>\n              <span className={`text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider ${mode === \'focus\' ? \'bg-indigo-50 text-indigo-600\' : \'bg-emerald-50 text-emerald-600\'}`}>\n                {mode === \"focus\" ? \"Focus Mode\" : \"Break Mode\"}\n              </span>\n              <p className=\"text-slate-400 text-xs mt-1\">Currently targeting: <span className=\"font-medium text-slate-600\">{activeCategory}</span></p>\n            </div>\n\n            <div className=\"flex gap-2\">\n              <button\n                onClick={() => selectDuration(25)}\n                className={`text-xs px-3 py-1.5 rounded-lg border transition-all ${\n                  duration === 25 && mode === \"focus\"\n                    ? \"bg-slate-900 border-slate-900 text-white\"\n                    : \"bg-white border-slate-200 text-slate-600 hover:border-slate-300\"\n                }`}\n              >\n                25m\n              </button>\n              <button\n                onClick={() => selectDuration(50)}\n                className={`text-xs px-3 py-1.5 rounded-lg border transition-all ${\n                  duration === 50 && mode === \"focus\"\n                    ? \"bg-slate-900 border-slate-900 text-white\"\n                    : \"bg-white border-slate-200 text-slate-600 hover:border-slate-300\"\n                }`}\n              >\n                50m\n              </button>\n            </div>\n          </div>\n\n          {/* Interactive Radial Timer Ring */}\n          <div className=\"relative z-10 w-64 h-64 flex items-center justify-center my-4\">\n            <svg className=\"w-full h-full transform -rotate-90\">\n              {/* Outer light ring */}\n              <circle\n                cx=\"128\"\n                cy=\"128\"\n                r=\"110\"\n                className=\"stroke-slate-100 fill-transparent\"\n                strokeWidth=\"8\"\n              />\n              {/* Animated active progress ring */}\n              <motion.circle\n                cx=\"128\"\n                cy=\"128\"\n                r=\"110\"\n                className={`fill-transparent ${mode === \'focus\' ? \'stroke-indigo-600\' : \'stroke-emerald-500\'}`}\n                strokeWidth=\"8\"\n                strokeDasharray=\"691.15\"\n                animate={{ strokeDashoffset: 691.15 * (1 - progress) }}\n                transition={{ duration: 0.35, ease: \"easeInOut\" }}\n                strokeLinecap=\"round\"\n              />\n            </svg>\n\n            {/* Time content in center */}\n            <div className=\"absolute flex flex-col items-center text-center\">\n              <span className=\"font-mono text-5xl font-semibold tracking-tighter text-slate-900\">\n                {formatTime(timeLeft)}\n              </span>\n              <span className=\"text-slate-400 text-xs mt-1 uppercase tracking-wider\">\n                {isRunning ? \"Focusing...\" : \"Paused\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Timer Action Buttons */}\n          <div className=\"relative z-10 flex gap-4 mt-6\">\n            <button\n              onClick={toggleTimer}\n              className={`flex items-center gap-2 px-6 py-3 rounded-full font-medium text-sm transition-all shadow-md hover:scale-105 active:scale-95 ${\n                isRunning\n                  ? \"bg-slate-900 text-white hover:bg-slate-800\"\n                  : \"bg-indigo-600 text-white hover:bg-indigo-500 shadow-indigo-200\"\n              }`}\n            >\n              {isRunning ? <Pause className=\"w-4 h-4\" /> : <Play className=\"w-4 h-4 fill-white\" />}\n              {isRunning ? \"Pause\" : \"Start Focus\"}\n            </button>\n\n            <button\n              onClick={resetTimer}\n              className=\"flex items-center gap-2 px-5 py-3 rounded-full font-medium text-sm border border-slate-200 text-slate-600 bg-white hover:bg-slate-50 transition-all hover:scale-105 active:scale-95\"\n            >\n              <RotateCcw className=\"w-4 h-4\" />\n              Reset\n            </button>\n          </div>\n\n          {/* Category Selector */}\n          <div className=\"relative z-10 w-full mt-8 border-t border-slate-100 pt-6\">\n            <p className=\"text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3 text-center\">\n              Associate with Activity Category:\n            </p>\n            <div className=\"flex flex-wrap justify-center gap-3\">\n              {CATEGORIES.map((cat) => (\n                <button\n                  key={cat.id}\n                  onClick={() => setActiveCategory(cat.id)}\n                  className={`flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-medium border transition-all ${\n                    activeCategory === cat.id\n                      ? `${cat.border} ${cat.text} bg-slate-50 font-semibold`\n                      : \"border-slate-200 text-slate-500 hover:border-slate-300\"\n                  }`}\n                >\n                  <span className={`w-2.5 h-2.5 rounded-full ${cat.color}`} />\n                  {cat.id}\n                </button>\n              ))}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Right Column: Statistics */}\n      <div className=\"space-y-6\">\n        {/* Quick Summary Card */}\n        <div id=\"stats-summary-card\" className=\"bg-slate-900 text-white border border-slate-800 rounded-2xl p-6 relative overflow-hidden shadow-md\">\n          <div className=\"absolute top-0 right-0 p-4 opacity-10\">\n            <Clock className=\"w-24 h-24 stroke-[1]\" />\n          </div>\n\n          <div className=\"relative z-10 flex items-center gap-2 mb-4 text-slate-400 text-xs font-semibold uppercase tracking-wider\">\n            <Flame className=\"w-4 h-4 text-orange-400 animate-pulse\" />\n            Productivity Summary\n          </div>\n\n          <div className=\"relative z-10 space-y-4\">\n            <div>\n              <p className=\"text-3xl font-semibold tracking-tight\">{totalMinutes}m</p>\n              <p className=\"text-slate-400 text-xs mt-0.5\">Total focus logged this session</p>\n            </div>\n\n            <div className=\"flex gap-4 pt-2 border-t border-slate-800 text-slate-300\">\n              <div>\n                <p className=\"text-lg font-medium\">{sessions.length}</p>\n                <p className=\"text-slate-500 text-[10px] uppercase tracking-wider\">Completed intervals</p>\n              </div>\n              <div>\n                <p className=\"text-lg font-medium\">\n                  {Math.round(sessions.length > 0 ? totalMinutes / sessions.length : 0)}m\n                </p>\n                <p className=\"text-slate-500 text-[10px] uppercase tracking-wider\">Average duration</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Custom Visual Distribution Chart */}\n        <div id=\"stats-distribution-card\" className=\"bg-white border border-slate-100 rounded-2xl p-6 shadow-xs\">\n          <div className=\"flex items-center justify-between mb-4\">\n            <div className=\"flex items-center gap-2 text-slate-800 text-xs font-semibold uppercase tracking-wider\">\n              <TrendingUp className=\"w-4 h-4 text-indigo-500\" />\n              Focus Distribution\n            </div>\n            {sessions.length > 0 && (\n              <button\n                onClick={onClearSessions}\n                className=\"text-[10px] text-red-500 hover:text-red-600 font-semibold uppercase tracking-wider hover:underline\"\n              >\n                Clear logs\n              </button>\n            )}\n          </div>\n\n          {sessions.length === 0 ? (\n            <div className=\"h-48 flex flex-col items-center justify-center text-center p-4 border-2 border-dashed border-slate-100 rounded-xl\">\n              <CheckCircle className=\"w-8 h-8 text-slate-200 mb-2\" />\n              <p className=\"text-xs font-medium text-slate-400\">No session logs found</p>\n              <p className=\"text-[10px] text-slate-300 mt-1 max-w-[200px]\">\n                Complete your first 25-minute Pomodoro focus interval to see visual analytical metrics here!\n              </p>\n            </div>\n          ) : (\n            <div className=\"space-y-4 pt-2\">\n              {CATEGORIES.map((cat) => {\n                const mins = categoryStats[cat.id] || 0;\n                const pct = Math.round((mins / maxMins) * 100);\n                return (\n                  <div key={cat.id} className=\"space-y-1.5\">\n                    <div className=\"flex justify-between text-xs font-medium\">\n                      <span className=\"text-slate-600 flex items-center gap-1.5\">\n                        <span className={`w-2 h-2 rounded-full ${cat.color}`} />\n                        {cat.id}\n                      </span>\n                      <span className=\"text-slate-800 font-semibold\">{mins} mins</span>\n                    </div>\n                    {/* Visual custom bar with progress animation */}\n                    <div className=\"w-full bg-slate-100 rounded-full h-3.5 overflow-hidden\">\n                      <motion.div\n                        className={`h-full ${cat.color} rounded-full`}\n                        initial={{ width: 0 }}\n                        animate={{ width: `${pct}%` }}\n                        transition={{ duration: 0.8, ease: \"easeOut\" }}\n                      />\n                    </div>\n                  </div>\n                );\n              })}\n\n              <div className=\"bg-slate-50 border border-slate-100 rounded-xl p-3 flex gap-2.5 items-start mt-4\">\n                <Sparkles className=\"w-4 h-4 text-indigo-500 shrink-0 mt-0.5\" />\n                <div>\n                  <p className=\"text-[11px] font-semibold text-slate-700\">Daily Tip</p>\n                  <p className=\"text-[10px] text-slate-500 leading-normal mt-0.5\">\n                    Switching categories keeps the mind active. Balance your 25m focus intervals with short breaks to improve retention.\n                  </p>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
