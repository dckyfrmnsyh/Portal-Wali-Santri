  file_change {
    absolute_path_uri: "file:///src/components/AetherSearch.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { Search, Sparkles, Globe, ArrowRight, History, Trash2, ExternalLink, ShieldAlert } from \"lucide-react\";\nimport { ResearchQuery } from \"../types\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface AetherSearchProps {\n  history: ResearchQuery[];\n  onAddQuery: (item: ResearchQuery) => void;\n  onClearHistory: () => void;\n}\n\n// Light Regex-based Markdown compiler that renders to structured, beautiful Tailwind elements\nconst renderMarkdown = (text: string) => {\n  if (!text) return null;\n\n  const lines = text.split(\"\\n\");\n  let inList = false;\n  let listItems: string[] = [];\n  const renderedElements: React.ReactNode[] = [];\n\n  const parseInlineMarkdown = (content: string) => {\n    content = content.replace(/\\*\\*(.*?)\\*\\*/g, \"<strong>$1</strong>\");\n    content = content.replace(/\\*(.*?)\\*/g, \"<em>$1</em>\");\n    content = content.replace(/`(.*?)`/g, \"<code class=\'bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\'>$1</code>\");\n    return <span dangerouslySetInnerHTML={{ __html: content }} />;\n  };\n\n  const flushList = (key: number) => {\n    if (listItems.length > 0) {\n      renderedElements.push(\n        <ul key={`list-${key}`} className=\"list-disc pl-6 space-y-1 mb-4 text-slate-600 text-sm\">\n          {listItems.map((item, idx) => (\n            <li key={idx}>{parseInlineMarkdown(item)}</li>\n          ))}\n        </ul>\n      );\n      listItems = [];\n      inList = false;\n    }\n  };\n\n  lines.forEach((line, index) => {\n    if (line.startsWith(\"# \")) {\n      flushList(index);\n      renderedElements.push(\n        <h1 key={index} className=\"text-xl font-bold text-slate-800 border-b border-slate-100 pb-2 mb-4 mt-6 first:mt-0\">\n          {parseInlineMarkdown(line.substring(2))}\n        </h1>\n      );\n    } else if (line.startsWith(\"## \")) {\n      flushList(index);\n      renderedElements.push(\n        <h2 key={index} className=\"text-lg font-bold text-slate-800 mb-3 mt-5\">\n          {parseInlineMarkdown(line.substring(3))}\n        </h2>\n      );\n    } else if (line.startsWith(\"- \") || line.startsWith(\"* \")) {\n      inList = true;\n      listItems.push(line.substring(2));\n    } else if (line.trim() === \"\") {\n      flushList(index);\n    } else {\n      flushList(index);\n      renderedElements.push(\n        <p key={index} className=\"text-slate-600 text-sm leading-relaxed mb-3\">\n          {parseInlineMarkdown(line)}\n        </p>\n      );\n    }\n  });\n\n  flushList(lines.length);\n  return <div className=\"space-y-1\">{renderedElements}</div>;\n};\n\nexport default function AetherSearch({ history, onAddQuery, onClearHistory }: AetherSearchProps) {\n  const [query, setQuery] = useState(\"\");\n  const [activeQueryId, setActiveQueryId] = useState<string | null>(null);\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  const activeQuery = history.find((h) => h.id === activeQueryId) || null;\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!query.trim() || isLoading) return;\n\n    setIsLoading(true);\n    setError(null);\n\n    try {\n      const response = await fetch(\"/api/research\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ prompt: query }),\n      });\n\n      const data = await response.json();\n      if (!response.ok) {\n        throw new Error(data.error || \"Failed to search information\");\n      }\n\n      const newQuery: ResearchQuery = {\n        id: crypto.randomUUID(),\n        query: query,\n        answer: data.text,\n        chunks: data.chunks || [],\n        webSearchQueries: data.webSearchQueries || [],\n        createdAt: new Date().toISOString(),\n      };\n\n      onAddQuery(newQuery);\n      setActiveQueryId(newQuery.id);\n      setQuery(\"\");\n    } catch (err: any) {\n      console.error(err);\n      setError(err.message || \"An unexpected error occurred while connecting with Gemini search grounding.\");\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  return (\n    <div id=\"aether-search-container\" className=\"grid grid-cols-1 xl:grid-cols-4 gap-6 h-[calc(100vh-180px)] min-h-[500px]\">\n      {/* Sidebar: Past Inquiries */}\n      <div className=\"xl:col-span-1 bg-white border border-slate-100 rounded-2xl p-4 shadow-xs flex flex-col h-full\">\n        <div className=\"flex items-center justify-between mb-4 pb-2 border-b border-slate-50\">\n          <div className=\"flex items-center gap-1.5 text-xs font-bold text-slate-400 uppercase tracking-wider\">\n            <History className=\"w-3.5 h-3.5\" />\n            Research History\n          </div>\n          {history.length > 0 && (\n            <button\n              onClick={onClearHistory}\n              className=\"p-1 hover:bg-slate-50 rounded text-slate-400 hover:text-red-500 transition-colors\"\n              title=\"Clear Search History\"\n            >\n              <Trash2 className=\"w-3.5 h-3.5\" />\n            </button>\n          )}\n        </div>\n\n        <div className=\"flex-1 overflow-y-auto space-y-2 pr-1 custom-scrollbar\">\n          {history.length === 0 ? (\n            <div className=\"text-center py-12 px-4 border-2 border-dashed border-slate-50 rounded-xl\">\n              <p className=\"text-xs font-medium text-slate-400\">No searches made yet</p>\n              <p className=\"text-[10px] text-slate-300 mt-1\">Submit a query to enable search citations</p>\n            </div>\n          ) : (\n            history.map((item) => (\n              <div\n                key={item.id}\n                onClick={() => setActiveQueryId(item.id)}\n                className={`flex items-start justify-between p-3 rounded-xl border cursor-pointer transition-all ${\n                  activeQueryId === item.id\n                    ? \"bg-indigo-50/50 border-indigo-100 text-slate-900\"\n                    : \"border-transparent bg-white hover:bg-slate-50 text-slate-600\"\n                }`}\n              >\n                <div className=\"flex-1 min-w-0 pr-2\">\n                  <p className=\"text-xs font-semibold truncate flex items-center gap-1.5\">\n                    <Globe className=\"w-3 h-3 text-indigo-500 shrink-0\" />\n                    {item.query}\n                  </p>\n                  <p className=\"text-[9px] text-slate-400 mt-1\">\n                    {new Date(item.createdAt).toLocaleTimeString()} \342\200\242 {item.chunks.length} citations\n                  </p>\n                </div>\n              </div>\n            ))\n          )}\n        </div>\n      </div>\n\n      {/* Main Grounded Workspace */}\n      <div className=\"xl:col-span-3 bg-white border border-slate-100 rounded-2xl p-5 shadow-xs flex flex-col h-full overflow-hidden\">\n        {/* Search Header Input bar */}\n        <form onSubmit={handleSubmit} className=\"mb-5 relative z-10 shrink-0\">\n          <div className=\"relative\">\n            <input\n              type=\"text\"\n              value={query}\n              onChange={(e) => setQuery(e.target.value)}\n              placeholder=\"Ask anything (e.g., \'What are the main findings in recent quantum computing papers?\')...\"\n              disabled={isLoading}\n              className=\"w-full pl-11 pr-24 py-3 bg-slate-50 border border-slate-100 rounded-2xl text-sm outline-hidden focus:ring-1 focus:ring-indigo-300 focus:border-indigo-400 text-slate-700 placeholder-slate-400 font-medium shadow-xs\"\n            />\n            <div className=\"absolute left-4 top-3.5 text-slate-400\">\n              <Search className=\"w-4 h-4\" />\n            </div>\n\n            <button\n              type=\"submit\"\n              disabled={isLoading || !query.trim()}\n              className=\"absolute right-2 top-1.5 px-4 py-1.5 bg-indigo-600 hover:bg-indigo-500 disabled:bg-slate-200 text-white disabled:text-slate-400 rounded-xl text-xs font-semibold flex items-center gap-1 transition-all hover:scale-102 active:scale-98\"\n            >\n              {isLoading ? (\n                <div className=\"w-3.5 h-3.5 border-2 border-white/30 border-t-white rounded-full animate-spin\" />\n              ) : (\n                <>\n                  <Sparkles className=\"w-3.5 h-3.5\" />\n                  Search\n                </>\n              )}\n            </button>\n          </div>\n        </form>\n\n        {/* Results / Answer Workspace */}\n        <div className=\"flex-1 min-h-0 overflow-hidden flex flex-col\">\n          {isLoading ? (\n            <div className=\"flex-1 flex flex-col items-center justify-center text-center p-6 space-y-4\">\n              <div className=\"relative\">\n                <div className=\"w-12 h-12 rounded-full border-4 border-indigo-100 border-t-indigo-600 animate-spin\" />\n                <div className=\"absolute inset-0 flex items-center justify-center\">\n                  <Globe className=\"w-5 h-5 text-indigo-500 animate-pulse\" />\n                </div>\n              </div>\n              <div>\n                <p className=\"text-xs font-semibold text-slate-700 animate-pulse\">Consulting Gemini & Google Search Grounding...</p>\n                <p className=\"text-[10px] text-slate-400 mt-1 max-w-[280px] mx-auto\">\n                  Verifying real-time citations and cross-checking references on the live web.\n                </p>\n              </div>\n            </div>\n          ) : error ? (\n            <div className=\"flex-1 flex flex-col items-center justify-center text-center p-6 text-red-500 bg-rose-50/30 rounded-xl border border-rose-100/50\">\n              <ShieldAlert className=\"w-10 h-10 text-rose-500 mb-2\" />\n              <p className=\"text-xs font-bold uppercase tracking-wider mb-1\">Search Failure</p>\n              <p className=\"text-[11px] text-rose-600 max-w-md\">{error}</p>\n              <button\n                onClick={() => setError(null)}\n                className=\"mt-4 text-[10px] text-slate-500 hover:text-slate-800 border border-slate-200 px-3 py-1.5 rounded-lg bg-white shadow-xs\"\n              >\n                Dismiss Error\n              </button>\n            </div>\n          ) : activeQuery ? (\n            <div className=\"flex-1 min-h-0 flex flex-col md:flex-row gap-6\">\n              {/* Answer content (Left) */}\n              <div className=\"flex-1 overflow-y-auto pr-2 custom-scrollbar\">\n                <div className=\"space-y-4\">\n                  <div className=\"pb-3 border-b border-slate-50\">\n                    <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider\">Inquiry:</span>\n                    <h3 className=\"font-bold text-slate-800 text-base mt-0.5\">{activeQuery.query}</h3>\n                  </div>\n\n                  <div className=\"prose prose-slate max-w-none\">\n                    {renderMarkdown(activeQuery.answer)}\n                  </div>\n                </div>\n              </div>\n\n              {/* Citations & Web Queries Sidebar (Right) */}\n              <div className=\"w-full md:w-64 bg-slate-50 border border-slate-100 rounded-xl p-4 flex flex-col gap-4 overflow-y-auto shrink-0\">\n                {/* Search Term tags */}\n                {activeQuery.webSearchQueries.length > 0 && (\n                  <div>\n                    <span className=\"text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-2\">Web Queries Ran:</span>\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      {activeQuery.webSearchQueries.map((q, idx) => (\n                        <span key={idx} className=\"text-[10px] bg-indigo-50 border border-indigo-100 text-indigo-700 px-2.5 py-1 rounded-full font-medium\">\n                          {q}\n                        </span>\n                      ))}\n                    </div>\n                  </div>\n                )}\n\n                {/* Sources list */}\n                <div>\n                  <span className=\"text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-2\">Sources Referenced:</span>\n                  {activeQuery.chunks.length === 0 ? (\n                    <p className=\"text-[10px] text-slate-400 italic\">No web references cited.</p>\n                  ) : (\n                    <div className=\"space-y-2\">\n                      {activeQuery.chunks.map((chunk, idx) => {\n                        const target = chunk.web || chunk.maps;\n                        if (!target) return null;\n                        return (\n                          <a\n                            key={idx}\n                            href={target.uri}\n                            target=\"_blank\"\n                            rel=\"noopener noreferrer\"\n                            className=\"block p-2.5 bg-white border border-slate-200/60 rounded-lg hover:border-indigo-400 group transition-all\"\n                          >\n                            <div className=\"flex items-start gap-1.5 justify-between\">\n                              <p className=\"text-[10px] font-semibold text-slate-700 line-clamp-2 leading-normal group-hover:text-indigo-600 transition-colors\">\n                                {target.title || \"Untitled Web Citation\"}\n                              </p>\n                              <ExternalLink className=\"w-3 h-3 text-slate-400 group-hover:text-indigo-500 shrink-0 mt-0.5\" />\n                            </div>\n                            <span className=\"text-[8px] text-slate-400 mt-1 block truncate max-w-[190px]\">\n                              {target.uri}\n                            </span>\n                          </a>\n                        );\n                      })}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          ) : (\n            <div className=\"flex-1 flex flex-col items-center justify-center text-center p-6 text-slate-400\">\n              <Globe className=\"w-12 h-12 text-slate-200 mb-3 animate-pulse\" />\n              <p className=\"text-sm font-semibold\">Ready for Grounded Search</p>\n              <p className=\"text-xs text-slate-300 mt-1 max-w-[280px]\">\n                Submit a factual research query. Gemini will consult the web and present cited reference sources in real-time.\n              </p>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
